# Firebase
FIREBASE_ENABLED=false
FIREBASE_CREDENTIALS_PATH=/path/to/serviceAccount.json
FIREBASE_PROJECT_ID=your-project-id

# OpenRouter (optional AI summaries)
AI_SUMMARY_ENABLED=false
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-flash-1.5

# RSS feed overrides (comma-separated URLs)
BOOK_RSS_FEEDS=
PUBLISHER_RSS_FEEDS=
REVIEW_RSS_FEEDS=

# Scheduler intervals
RSS_REFRESH_HOURS=1
RETRY_FAILED_MINUTES=30
WEEKLY_CLEANUP_DAY=sun
WEEKLY_CLEANUP_HOUR=3
DUPLICATE_CLEANUP_HOURS=24

# Firebase
FIREBASE_ENABLED=false
FIREBASE_CREDENTIALS_PATH=/path/to/serviceAccount.json
FIREBASE_PROJECT_ID=your-project-id

# OpenRouter (optional AI summaries)
AI_SUMMARY_ENABLED=false
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-flash-1.5

# RSS feed overrides (comma-separated URLs)
BOOK_RSS_FEEDS=
PUBLISHER_RSS_FEEDS=
REVIEW_RSS_FEEDS=

# Scheduler / performance tuning
RSS_FETCH_WORKERS=6
FEED_WORKERS=3
ARTICLE_FETCH_WORKERS=8

# Dedupe: false = refresh all JSON each run (recommended). true = skip URLs seen before.
DEDUPE_PERSIST=false

# Thumbnail enrichment (higher = slower, better covers). ~4–5 min with 15.
ARTICLE_ENRICHMENT_MAX=15
RSS_REFRESH_HOURS=1
RETRY_FAILED_MINUTES=30
WEEKLY_CLEANUP_DAY=sun
WEEKLY_CLEANUP_HOUR=3
DUPLICATE_CLEANUP_HOURS=24
